source:
  # mythtv | tvheadend
  type: mythtv

  mythtv:
    host:
    user:
    password:
    database: mythconverg
    poll_interval: 300

  tvheadend:
    url:

    authentication:
      type: basic              # basic | persistent_auth
      username:
      password:
      auth_code:

destination:
  type: tvheadend

  tvheadend:
    enabled: false
    url:

    authentication:
      type: basic              # basic | persistent_auth
      username:
      password:
      auth_code:

    output:
      directory:

    delete_source_after_import: false
    comment: imported by tv-converter

    channel_mapping:
      # "ZDF HD": "ZDF"
      # "Das Erste HD": "Das Erste HD"

encoder:
  type: auto                  # auto | sw | qsv | vaapi | none
  copy_hevc: true
  audio_quality: "2"

  qsv:
    device: /dev/dri/renderD128
    extra_hw_frames: 10

  vaapi:
    device: /dev/dri/renderD128
    rc_mode: ICQ
    extra_hw_frames: 10

profiles:
  sd:
    min_height: 0
    preset: fast
    crf: 28
    qsv_global_quality: 28
    vaapi_qp: 29

  hd:
    min_height: 720
    preset: slow
    crf: 24
    qsv_global_quality: 24
    vaapi_qp: 25

mqtt:
  enabled: false
  broker:
  port: 1883
  username:
  password:
  topic:
  topic_prefix: tv-converter
  json_path:
  pause_watt: 0
  resume_watt: 50
  timeout_seconds: 30

postprocessing:
  plex:
    enabled: false
    refresh_url:
    verify_ssl: false
    suppress_ssl_warning: true
    timeout: 10

output:
  description_fallback_chars: 25

permissions:
  file_mode: "664"

selection:
  min_minutes: 1
  limit: 0
  title_contains:
  channel_contains:

logging:
  level: normal
